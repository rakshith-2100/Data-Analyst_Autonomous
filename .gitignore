# ─────────────────────────────────────────────────────────────
# Secrets & environment
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
secrets.*

# ─────────────────────────────────────────────────────────────
# Project-specific
# ─────────────────────────────────────────────────────────────
# Reproducible dataset — re-download via the wget/curl in the README.
# Ignore the whole folder (data is not committed).
data/
# Per-session run traces (regenerated every run; can get large).
traces/
*.jsonl
# Runtime logs (regenerated every run). Keep the folder structure, ignore contents.
data_analyst/logs/*.log
data_analyst/logs/prompts_response/*.log
# Sandbox chart/artifact output.
out/
app/out/

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# ─────────────────────────────────────────────────────────────
# Node / React frontend (app/)
# ─────────────────────────────────────────────────────────────
node_modules/
app/node_modules/
app/dist/
app/build/
.npm/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

