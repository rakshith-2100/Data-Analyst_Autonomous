# Copy this file to `.env` (which is gitignored) and fill in your real key.
#   cp .env.example .env      # then edit OPENAI_API_KEY
# Never commit the real .env — only this example is tracked.

OPENAI_API_KEY=sk-your-openai-key-here

# Model tiers (override if you prefer different GPT models)
OPENAI_MODEL_CHEAP=gpt-4.1-mini
OPENAI_MODEL_STRONG=gpt-4.1
